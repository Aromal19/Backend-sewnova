# Production Environment Variables for SewNova Backend
# Copy this file to .env.production and update with your actual production values

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/sewnova_production

# JWT Secrets
JWT_SECRET=your-super-secure-jwt-secret-key-here
JWT_REFRESH_SECRET=your-super-secure-refresh-secret-key-here

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Razorpay Payment
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Email Service
EMAIL_SERVICE_API_KEY=your-email-service-api-key
EMAIL_FROM=noreply@sewnova.com

# Service Ports
AUTH_SERVICE_PORT=3001
CUSTOMER_SERVICE_PORT=3002
ADMIN_SERVICE_PORT=3003
DESIGN_SERVICE_PORT=3004
TAILOR_SERVICE_PORT=3005
VENDOR_SERVICE_PORT=3006
PAYMENT_SERVICE_PORT=3007
MEASUREMENT_SERVICE_PORT=8001

# CORS
CORS_ORIGIN=https://your-frontend-domain.vercel.app

# Environment
NODE_ENV=production
